# Environment name (DEV triggers mock login visibility)
NEXT_PUBLIC_ENV_NAME=DEV

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Azure AD Configuration
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-azure-client-id
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-azure-tenant-id

# Optional: Override redirect URI if it differently registered in Azure portal
# Defaults to window.location.origin + "/auth/callback" if not set
# NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/callback
